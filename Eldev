; -*- mode: emacs-lisp; lexical-binding: t; no-byte-compile: t -*-

;; explicitly set main file
(setf eldev-project-main-file "vulpea-para.el")

(eldev-require-version "0.10.3")

(eldev-use-package-archive 'gnu)
(eldev-use-package-archive 'melpa-unstable)

;; Use the sibling vulpea checkout during development, so vulpea-para is
;; always tested against the vulpea you actually have here.
(eldev-use-local-dependency "../vulpea")

;; allow to load test helpers
(eldev-add-loading-roots 'test "test")

;; Tell checkdoc not to demand two spaces after a period.
(setq sentence-end-double-space nil)
